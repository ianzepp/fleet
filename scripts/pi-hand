#!/usr/bin/env bash
# pi-hand — Pi harness for Fleet Hands (implementers).
#
# Strips extension discovery so the Fleet Mind extension cannot load from
# settings and Hands cannot fleet_attach / run Mind loops in worker panes.
# Explicit -e paths still work if an operator intentionally passes them.
#
# Part of the Fleet skill (not a global product requirement). Prefer this as
# agent_launch for Hand roles in fleet.json.
#
# Usage: pi-hand [same args as pi …]
# Env:
#   PI_BIN     override pi binary (default: first `pi` on PATH)
#   PI_HAND_EXTRA  extra args injected after safety flags (word-split)

set -euo pipefail

pi_bin="${PI_BIN:-}"
if [[ -z "$pi_bin" ]]; then
  if command -v pi >/dev/null 2>&1; then
    pi_bin="$(command -v pi)"
  else
    printf 'pi-hand: pi not found on PATH; set PI_BIN\n' >&2
    exit 127
  fi
fi

# Skip re-injecting if caller already set --no-extensions / -ne
has_ne=0
for arg in "$@"; do
  case "$arg" in
    --no-extensions|-ne) has_ne=1 ;;
  esac
done

extra=()
if [[ "$has_ne" -eq 0 ]]; then
  extra+=(--no-extensions)
fi

# Optional operator extras (e.g. --offline)
# shellcheck disable=SC2206
if [[ -n "${PI_HAND_EXTRA:-}" ]]; then
  extra+=(${PI_HAND_EXTRA})
fi

if [[ ${#extra[@]} -gt 0 ]]; then
  exec "$pi_bin" "${extra[@]}" "$@"
fi
exec "$pi_bin" "$@"
