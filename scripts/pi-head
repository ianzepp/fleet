#!/usr/bin/env bash
# pi-head — Pi harness for Fleet Heads (analysts / advisors).
#
# 1) --no-extensions — no Fleet Mind extension (Heads do not attach as Mind;
#    no fleet_attach in worker panes).
# 2) --exclude-tools edit,write — deny built-in mutating file tools. Heads should
#    analyze and report via mail; implementation belongs to Hands.
#
# Bash remains available (needed for rg/git/read-only probes). Head policy still
# forbids destructive git and product implementation — tool denylist is a
# seatbelt, not a sandbox.
#
# Part of the Fleet skill. Prefer this as agent_launch for Head roles.
#
# Usage: pi-head [same args as pi …]
# Env:
#   PI_BIN      override pi binary
#   PI_HEAD_EXTRA  extra args after safety flags
#   PI_HEAD_EXCLUDE_TOOLS  default: edit,write  (comma-separated)

set -euo pipefail

pi_bin="${PI_BIN:-}"
if [[ -z "$pi_bin" ]]; then
  if command -v pi >/dev/null 2>&1; then
    pi_bin="$(command -v pi)"
  else
    printf 'pi-head: pi not found on PATH; set PI_BIN\n' >&2
    exit 127
  fi
fi

has_ne=0
has_xt=0
for arg in "$@"; do
  case "$arg" in
    --no-extensions|-ne) has_ne=1 ;;
    --exclude-tools|-xt|--exclude-tools=*|-xt=*) has_xt=1 ;;
  esac
done

exclude_tools="${PI_HEAD_EXCLUDE_TOOLS:-edit,write}"

extra=()
if [[ "$has_ne" -eq 0 ]]; then
  extra+=(--no-extensions)
fi
if [[ "$has_xt" -eq 0 ]]; then
  extra+=(--exclude-tools "$exclude_tools")
fi

# shellcheck disable=SC2206
if [[ -n "${PI_HEAD_EXTRA:-}" ]]; then
  extra+=(${PI_HEAD_EXTRA})
fi

if [[ ${#extra[@]} -gt 0 ]]; then
  exec "$pi_bin" "${extra[@]}" "$@"
fi
exec "$pi_bin" "$@"
